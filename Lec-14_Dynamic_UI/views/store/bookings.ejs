<%- include('../partials/head', { pageTitle: 'My Bookings' }) %>
</head>
<body class="bg-gradient-to-b from-gray-50 to-gray-100 min-h-screen">
  <!-- Navbar -->
  <%- include('../partials/Navbar') %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Header Section -->
    <div class="mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-2">My Bookings</h1>
      <p class="text-xl text-gray-600">Manage and track all your upcoming and past reservations</p>
    </div>

    <!-- Tabs Section -->
    <div class="mb-8 border-b border-gray-300">
      <div class="flex gap-8">
        <button class="pb-4 px-2 border-b-4 border-red-500 font-semibold text-red-500 hover:text-red-600 transition">
          Active Bookings
        </button>
        <button class="pb-4 px-2 border-b-4 border-transparent font-semibold text-gray-600 hover:text-gray-800 transition">
          Past Bookings
        </button>
        <button class="pb-4 px-2 border-b-4 border-transparent font-semibold text-gray-600 hover:text-gray-800 transition">
          Cancelled
        </button>
      </div>
    </div>

    <!-- Bookings Container -->
    <section>
      <% if (bookings && bookings.length === 0) { %>
        <!-- Empty State -->
        <div class="bg-white rounded-2xl shadow-lg p-16 text-center">
          <div class="mb-6">
            <svg class="w-24 h-24 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h18M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
          </div>
          <h3 class="text-3xl font-bold text-gray-800 mb-3">No Active Bookings</h3>
          <p class="text-gray-600 text-lg mb-8">You don't have any active bookings yet. Explore our homes and make your first reservation!</p>
          <a href="/" class="inline-block bg-red-500 hover:bg-red-600 text-white font-bold py-3 px-8 rounded-lg transition transform hover:scale-105 shadow-md">
            🏠 Browse Homes
          </a>
        </div>

      <% } else { %>
        <!-- Bookings List -->
        <div class="space-y-6">

          <% bookings.forEach((booking, index) => { %>
            <!-- Booking Card -->
            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-all duration-300">
              <div class="grid grid-cols-1 md:grid-cols-4 gap-6 p-6 md:p-8">
                
                <!-- Image Section -->
                <div class="md:col-span-1">
                  <div class="relative rounded-lg overflow-hidden bg-gray-200 h-48 md:h-40">
                    <img src="<%= booking.homeImage %>" 
                         alt="<%= booking.homeName %>" 
                         class="w-full h-full object-cover hover:scale-110 transition-transform duration-300">
                    <div class="absolute top-3 right-3 bg-green-500 text-white px-3 py-1 rounded-full text-xs font-bold">
                      Confirmed
                    </div>
                  </div>
                </div>

                <!-- Booking Details -->
                <div class="md:col-span-2">
                  <h3 class="text-2xl font-bold text-gray-800 mb-2">
                    <%= booking.homeName %>
                  </h3>
                  <p class="text-gray-600 mb-4">
                    📍 <%= booking.location %>
                  </p>

                  <!-- Dates and Details -->
                  <div class="space-y-2 text-gray-700">
                    <div class="flex items-center gap-3">
                      <span class="font-semibold text-gray-800">Check-in:</span>
                      <span><%= booking.checkInDate %></span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="font-semibold text-gray-800">Check-out:</span>
                      <span><%= booking.checkOutDate %></span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="font-semibold text-gray-800">Duration:</span>
                      <span><%= booking.nights %> nights</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <span class="font-semibold text-gray-800">Guests:</span>
                      <span><%= booking.guests %> person<%= booking.guests > 1 ? 's' : '' %></span>
                    </div>
                  </div>
                </div>

                <!-- Price and Actions -->
                <div class="md:col-span-1 flex flex-col justify-between">
                  <!-- Price Summary -->
                  <div class="bg-gray-50 rounded-lg p-4 mb-4">
                    <p class="text-gray-600 text-sm mb-1">Total Price</p>
                    <p class="text-3xl font-bold text-gray-900">
                      $<%= booking.totalPrice %>
                    </p>
                    <p class="text-gray-500 text-xs mt-2">
                      $<%= booking.pricePerNight %> x <%= booking.nights %> nights
                    </p>
                  </div>

                  <!-- Action Buttons -->
                  <div class="space-y-2">
                    <button class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg transition transform hover:scale-105">
                      📋 View Details
                    </button>
                    <button class="w-full bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded-lg transition transform hover:scale-105">
                      🚫 Cancel Booking
                    </button>
                  </div>
                </div>

              </div>

              <!-- Bottom Status Bar -->
              <div class="border-t border-gray-200 bg-gray-50 px-6 md:px-8 py-3 rounded-b-xl">
                <div class="flex justify-between items-center">
                  <span class="text-sm text-gray-600">
                    Booking ID: <span class="font-mono font-semibold">#BK<%= String(index + 1).padStart(6, '0') %></span>
                  </span>
                  <span class="flex items-center gap-2 text-sm">
                    <span class="w-3 h-3 bg-green-500 rounded-full"></span>
                    <span class="text-gray-700">Confirmed on <%= booking.bookingDate %></span>
                  </span>
                </div>
              </div>
            </div>
          <% }) %>

        </div>
      <% } %>
    </section>

    <!-- FAQ Section -->
    <section class="mt-16 bg-white rounded-2xl shadow-lg p-8 md:p-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Booking Help</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- FAQ Item 1 -->
        <div class="border-l-4 border-red-500 pl-6">
          <h3 class="text-lg font-bold text-gray-800 mb-2">How do I cancel a booking?</h3>
          <p class="text-gray-600">You can cancel your booking up to 48 hours before check-in for a full refund. Click the 'Cancel Booking' button on your reservation.</p>
        </div>

        <!-- FAQ Item 2 -->
        <div class="border-l-4 border-red-500 pl-6">
          <h3 class="text-lg font-bold text-gray-800 mb-2">How do I modify check-in dates?</h3>
          <p class="text-gray-600">Contact the host directly through our messaging system or cancel and rebook with new dates. Some hosts offer flexible modifications.</p>
        </div>

        <!-- FAQ Item 3 -->
        <div class="border-l-4 border-red-500 pl-6">
          <h3 class="text-lg font-bold text-gray-800 mb-2">What's your refund policy?</h3>
          <p class="text-gray-600">Refunds depend on the host's cancellation policy. Most offer full refunds if cancelled 48 hours before check-in.</p>
        </div>

        <!-- FAQ Item 4 -->
        <div class="border-l-4 border-red-500 pl-6">
          <h3 class="text-lg font-bold text-gray-800 mb-2">Do I need travel insurance?</h3>
          <p class="text-gray-600">While not required, we recommend booking travel insurance for added peace of mind and protection.</p>
        </div>
      </div>
    </section>

  </main>

</body>
</html>
